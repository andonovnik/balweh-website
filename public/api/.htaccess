## SMTP configuration for contact form (PHPMailer)
SetEnv SMTP_HOST smtp.hostinger.com
SetEnv SMTP_PORT 465
SetEnv SMTP_USERNAME no-reply@balweh.de
SetEnv SMTP_PASSWORD t^9NsfwY>lk:
SetEnv SMTP_FROM_EMAIL no-reply@balweh.de
SetEnv SMTP_FROM_NAME "Balweh Gebäudereinigung und Galabau"

# Protect secret key files and other dotfiles in /api
<FilesMatch "^\.">
Require all denied
</FilesMatch>

# Prevent browser/proxy caching to reduce data retention risk.
<IfModule mod_headers.c>
  Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  Header always set Pragma "no-cache"
  Header always set Expires "0"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Monitoring key for /api/monitoring-health.php
SetEnv MONITORING_HEALTH_KEY 98H0sYjkBaRVH4pNCZD21eGqZjijaOXx9+SrZIcKoBS4SnEjCxUUpQUWMIWePixt

